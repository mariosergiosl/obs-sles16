# =============================================================================
# obsredis.te — Política SELinux para o daemon obsredis (bs_redis)
# =============================================================================
# Permite que o bs_redis (domínio init_t) crie e manipule o arquivo
# FIFO .ping no diretório /srv/obs/events/redis/ (contexto var_t).
#
# Contexto: OBS branch Unstable no SLES 16 sem política SELinux nativa.
#
# Processo de descoberta: 4 iterações com audit2allow durante o lab,
# evoluindo do código de saída 13 (EACCES) até active (running).
# Ver: docs/06-selinux.md#histórico-do-processo-obsredis
#
# Instalação:
#   checkmodule -M -m -o /tmp/obsredis.mod configs/selinux/obsredis.te
#   semodule_package -o /tmp/obsredis.pp -m /tmp/obsredis.mod
#   semodule -i /tmp/obsredis.pp
#
# Ou use o script automatizado:
#   bash scripts/apply-selinux-policy.sh
#
# Verificação:
#   semodule -l | grep obsredis
#
# Remoção:
#   semodule -r obsredis
# =============================================================================

module obsredis 1.0;

require {
    type init_t;
    type var_t;
    class fifo_file { create read write open ioctl };
    class dir { add_name write search };
}

# Permite que bs_redis (init_t) crie, abra, leia, escreva e faça ioctl
# no arquivo FIFO .ping com contexto var_t
allow init_t var_t:fifo_file { create read write open ioctl };

# Permite navegação e criação de arquivos no diretório pai (var_t)
allow init_t var_t:dir { add_name write search };
